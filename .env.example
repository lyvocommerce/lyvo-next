# Database (required for Prisma). Use .env or shell for DATABASE_URL.
# DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# Admin panel: single shared password. Set in .env.local for dev.
# Required to access /admin and /api/admin/* (login at /admin/login).
ADMIN_PASSWORD=

# Vercel Blob: for category image uploads in /admin/categories.
# 1. Vercel Dashboard → Storage → Create Database → Blob → Create store.
# 2. Open the store → Settings → copy "Read-Write" token.
# 3. Add below (locally in .env.local; on Vercel: Project → Settings → Environment Variables).
# Without this, uploads will fail with "No token found".
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx
